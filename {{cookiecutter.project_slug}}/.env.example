# Application
PROJECT_NAME={{ cookiecutter.project_name }}
VERSION={{ cookiecutter.version }}
DEBUG=false
{%- if cookiecutter.use_postgresql == 'y' %}

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/{{ cookiecutter.project_slug }}
{%- endif %}
{%- if cookiecutter.use_opentelemetry == 'y' %}

# OpenTelemetry (zero-code via opentelemetry-instrument CLI)
# See: https://opentelemetry.io/docs/specs/otel/configuration/sdk-environment-variables/
OTEL_SERVICE_NAME={{ cookiecutter.project_slug }}
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
OTEL_TRACES_EXPORTER=otlp_proto_http
OTEL_METRICS_EXPORTER=none
OTEL_LOGS_EXPORTER=none
OTEL_RESOURCE_ATTRIBUTES=service.version={{ cookiecutter.version }},deployment.environment=local
# OTEL_SDK_DISABLED=true  # uncomment to disable all tracing
# Caveat: production multi-worker (uvicorn --workers N) without gunicorn post_fork
# may lose worker spans. For real production, consider gunicorn + post_fork hook.
{%- endif %}
